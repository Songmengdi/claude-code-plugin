                  "id": "sfbVS",
                  "fill": "#a6adc8",
                  "content": "1  export function formatDate(date: Date): string {",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "87voY",
                  "fill": "#a6adc8",
                  "content": "2    const year = date.getFullYear();",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "quXtI",
                  "fill": "#a6adc8",
                  "content": "3    const month = String(date.getMonth() + 1).padStart(2, \"0\");",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "66uAU",
                  "fill": "#a6adc8",
                  "content": "4    const day = String(date.getDate()).padStart(2, \"0\");",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "t8xhR",
                  "fill": "#a6adc8",
                  "content": "5    return year + month + day;",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 11,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "hwJjH",
                  "fill": "#a6adc8",
